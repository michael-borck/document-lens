{
  "name": "document-lens",
  "version": "0.30.0",
  "description": "Desktop research tool for analyzing document collections through keyword frameworks. Map documents to domains, track terminology, and surface patterns across corpora.",
  "main": "dist-electron/main.js",
  "author": "Michael Borck",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michael-borck/document-lens.git"
  },
  "scripts": {
    "dev": "vite",
    "dev:tauri": "node scripts/tauri.mjs dev",
    "build:tauri": "node scripts/tauri.mjs build",
    "tauri": "node scripts/tauri.mjs",
    "gen:rust-db": "node --experimental-strip-types --no-warnings scripts/gen-rust-db.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build:vite && electron-builder",
    "build:vite": "tsc && vite build",
    "build:mac": "npm run build:vite && electron-builder --mac",
    "build:win": "npm run build:vite && electron-builder --win",
    "build:linux": "npm run build:vite && electron-builder --linux",
    "build:all": "npm run build:vite && electron-builder --mac --win --linux",
    "build:manual": "./manual/build-manual.sh",
    "build:corpus": "node scripts/build-test-corpus.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src electron",
    "postinstall": "electron-builder install-app-deps",
    "capture:help": "node scripts/capture-help-screenshots.mjs",
    "test:e2e": "npm run build:vite && playwright test",
    "test:e2e:only": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@visx/scale": "^3.12.0",
    "@visx/text": "^3.12.0",
    "@visx/wordcloud": "^3.12.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-cloud": "^1.2.9",
    "docx": "^9.7.1",
    "electron-updater": "^6.8.9",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.1",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "electron": "^38.8.6",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.60.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^2.1.8"
  }
}
