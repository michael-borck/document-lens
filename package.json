{
  "name": "document-lens",
  "version": "0.27.1",
  "description": "Desktop research tool for analyzing document collections through keyword frameworks. Map documents to domains, track terminology, and surface patterns across corpora.",
  "main": "dist-electron/main.js",
  "author": "Michael Borck",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michael-borck/document-lens.git"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run build:vite && electron-builder",
    "build:vite": "tsc && vite build",
    "build:mac": "npm run build:vite && electron-builder --mac",
    "build:win": "npm run build:vite && electron-builder --win",
    "build:linux": "npm run build:vite && electron-builder --linux",
    "build:all": "npm run build:vite && electron-builder --mac --win --linux",
    "build:manual": "./manual/build-manual.sh",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src electron",
    "postinstall": "electron-builder install-app-deps",
    "capture:help": "node scripts/capture-help-screenshots.mjs",
    "test:e2e": "npm run build:vite && playwright test",
    "test:e2e:only": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@visx/scale": "^3.12.0",
    "@visx/text": "^3.12.0",
    "@visx/wordcloud": "^3.12.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-cloud": "^1.2.7",
    "docx": "^9.7.1",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.14.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.0.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "electron": "^38.8.6",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.60.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.10"
  }
}
