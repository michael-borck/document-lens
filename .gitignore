# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.eslintcache
.node_repl_history
*.tgz
.yarn-integrity

# TypeScript
*.tsbuildinfo

# Vite / build output
dist/
dist-electron/
release/
manual/build/

# Electron-builder
release/

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log

# Editor / OS
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
.idea/
.vscode/

# Stray local PDF exports at the repo root (the shipped user manual is tracked
# explicitly; ad-hoc exports should not be committed).
/Untitled.pdf
/document-lens.pdf
*.iml
*~
\#*\#
.\#*
.history/

# Playwright e2e artefacts
/test-results/
/playwright-report/
/playwright/.cache/

# Testing / coverage
# NOTE: leading slash on /coverage/ anchors the rule to repo root.
# Without it, ANY nested coverage/ folder is ignored — which silently
# excluded src/components/coverage/ from git for the whole Phase 2 +
# Phase 3.5 work and only surfaced when CI on Linux failed typecheck.
.coverage
/coverage/
htmlcov/
coverage.xml

# Local SQLite
*.db
*.sqlite
*.sqlite3

# Claude Code tooling
.claude/

# User-local samples / manual artefacts (samples/* rather than samples/ so
# the test-corpus negations below can reach inside the directory)
samples/*
*.pdf
# …except the generated manual: committed so packaged builds (CI has no
# pandoc/typst) can bundle it via extraResources. Rebuild: npm run build:manual
!Document-Lens-User-Manual.pdf
# …and except the synthetic test-corpus SOURCES (ADR-0028): markdown docs +
# manifest + README are committed; generated PDFs stay ignored and are
# rebuilt with `npm run build:corpus`.
!samples/test-corpus/
samples/test-corpus/*
!samples/test-corpus/README.md
!samples/test-corpus/corpus-manifest.json
!samples/test-corpus/docs/

.superpowers/
