{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Document Lens",
  "version": "0.29.0",
  "identifier": "com.documentlens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Document Lens",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
