{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Document Lens",
  "version": "0.30.0",
  "identifier": "com.documentlens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Document Lens",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../Document-Lens-User-Manual.pdf": "Document-Lens-User-Manual.pdf"
    },
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "../build/entitlements.mac.plist",
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/michael-borck/document-lens/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwRkI4NDQxNTBBMUZCOTAKUldTUSs2RlFRWVQ3Z0wwNkFpbVJMdm1GZDZwTjlWSUkzYithUVhhRW5JeWpwL0tvcVAyeUFRRWYK"
    }
  }
}
